---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Ishan Kunkur, product leader in risk, payments, and AI.', image } = Astro.props;
const site = 'https://ishankunkur.com';
const year = new Date().getFullYear();
const ogImage = image ? (image.startsWith('http') ? image : `${site}${image}`) : `${site}/og.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500;1,6..72,600&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <div class="container">
      <nav class="nav">
        <a href="/" class="nav-brand">ishan kunkur</a>
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode">
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        </button>
        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
        <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </label>
        <div class="nav-links">
          <a href="/#about">About</a>
          <a href="/#projects">Projects</a>
          <a href="/#track">Chapters</a>
          <a href="/reading">Reading</a>
          <a href="/blog">Writing</a>
        </div>
      </nav>

      <slot />

      <footer class="footer">
        <span>© {year} Ishan Kunkur</span>
        <span>
          <a href="https://github.com/Ishan-Kunkur" target="_blank" rel="noopener">GitHub</a>
          &nbsp;·&nbsp;
          <a href="https://www.linkedin.com/in/ishankunkur" target="_blank" rel="noopener">LinkedIn</a>
        </span>
      </footer>
    </div>
    <script is:inline>
      // Close the mobile menu after tapping a nav link
      document.querySelectorAll('.nav-links a').forEach((link) => {
        link.addEventListener('click', () => {
          const toggle = document.getElementById('nav-toggle');
          if (toggle) toggle.checked = false;
        });
      });

      // Light / dark theme toggle
      const themeBtn = document.getElementById('theme-toggle');
      if (themeBtn) {
        themeBtn.addEventListener('click', () => {
          const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
