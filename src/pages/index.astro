---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import fs from 'node:fs';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Show the photo if it exists in /public, else a nice initials fallback.
const hasPhoto = fs.existsSync(new URL('../../public/Ishan.jpeg', import.meta.url));
---

<Base title="Ishan Kunkur · Data, Analytics & Product">
  <section class="hero">
    <h1>
      Hi, I'm Ishan. I turn strategy and data into products, and
      <span class="gradient-text">chaos into consensus</span>.
    </h1>
    <p>
      I love building cool stuff with cool people.
    </p>
    <div class="hero-links">
      <a href="/#projects" class="btn btn-primary">See my work</a>
      <a href="mailto:ishangvkunkur@gmail.com" class="btn">Get in touch</a>
    </div>
  </section>

  <section class="section" id="about">
    <div class="section-label">About</div>
    <div class="about">
      {hasPhoto ? (
        <img class="about-photo" src="/Ishan.jpeg" alt="Ishan Kunkur" />
      ) : (
        <div class="about-photo about-photo-fallback">IK</div>
      )}
      <div class="about-body">
        <p>
          I started in data and never really left. I just kept trading up for bigger
          problems to solve, which pulled me from SQL and dashboards into Python and
          machine learning, and eventually into a seat where I had a say in what we
          built and who we brought in to ship it. These days I'm building AI agents
          and products that make sense of payments risk at Walmart. AI is a great
          equalizer: it knocked down the wall between having an idea and actually
          shipping it.
        </p>
        <p>
          Lately that same curiosity has me poking under the hood, into how systems
          scale and stay secure, learning each new piece as the work demands it. The
          constant across all of it: build things people love, not just things that
          work.
        </p>
        <p>
          I'm an introvert who learned to love a full room of people. When I'm not
          building, you'll find me on a trail, in a video game, watching anime, or
          lost in a book. I also take food and coffee far too seriously. And I'll
          happily talk your ear off about any of it.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="projects">
    <div class="section-label">Things I build</div>
    <p style="color: var(--text-muted); margin-bottom: 28px; max-width: 560px;">
      Side projects I make on my own time, usually to learn something new, or just
      for the fun of it.
    </p>

    <div class="card">
      <h3>Agentic Trading</h3>
      <p>
        An ongoing exploration of how agentic systems can reason about markets,
        weigh ideas, and act with a human in the loop. Mostly an excuse to learn
        how autonomous agents actually behave when the stakes feel real.
      </p>
      <div class="meta">LLM agents · Python · Claude API</div>
    </div>

    <div class="card">
      <h3>TasteGraph</h3>
      <p>
        An AI app for people who take food too seriously (guilty). It learns your
        palate, the cuisines, flavors, and vibe you actually go for, turns it into a
        food personality, then points you to restaurants worth your time.
      </p>
      <div class="meta">Next.js · Claude API · Supabase · Personalization</div>
    </div>

    <div class="card">
      <h3>SnoutSketch</h3>
      <p>
        A playful web app that turns a close-up of your dog's snout into
        one-of-a-kind art, reading the unique ridges of their nose and rendering
        it in styles from vibrant to surreal to line art. Dheera was the first model.
      </p>
      <div class="meta">
        JavaScript · Generative AI · Web ·
        <a href="https://github.com/Ishan-Kunkur/SnoutSketch" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

  <section class="section" id="journey">
    <div class="section-label">My Journey</div>
    <p style="color: var(--text-muted); margin-bottom: 40px; max-width: 560px;">
      Ten years, three chapters, each building on the last: from data, to machine
      learning, to AI and product.
    </p>
    <div class="timeline">
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-year">2017</div>
        <div class="tl-phase">Data &amp; BI</div>
        <div class="tl-desc">
          Turning raw data into decisions leaders could act on.
        </div>
        <div class="chips">
          <span class="chip">SQL</span>
          <span class="chip">Power BI</span>
          <span class="chip">Data Governance</span>
        </div>
      </div>

      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-year">2021</div>
        <div class="tl-phase">Programming &amp; ML</div>
        <div class="tl-desc">
          Finding the patterns humans were missing across risk data.
        </div>
        <div class="chips">
          <span class="chip">Python</span>
          <span class="chip">Tableau</span>
          <span class="chip">Machine Learning</span>
        </div>
      </div>

      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-year">2024</div>
        <div class="tl-phase">AI &amp; Product</div>
        <div class="tl-desc">
          Shipping production ML and multi-agent AI, and going deeper on the craft of product.
        </div>
        <div class="chips">
          <span class="chip">Claude API</span>
          <span class="chip">Multi-agent AI</span>
          <span class="chip">Product</span>
          <span class="chip">AWS / GCP</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="interests">
    <div class="section-label">Areas of interest</div>
    <p style="color: var(--text-muted); margin-bottom: 28px; max-width: 560px;">
      Beyond the day job, the ideas I happily fall down rabbit holes on, the ones
      that genuinely bring me joy.
    </p>
    <div class="pills">
      <span class="pill">Financial Products</span>
      <span class="pill">Fintech</span>
      <span class="pill">Payments</span>
      <span class="pill">Risk Management</span>
      <span class="pill">Data</span>
      <span class="pill">Analytics</span>
      <span class="pill">Product Management</span>
      <span class="pill">AI</span>
      <span class="pill">Machine Learning</span>
      <span class="pill">LLMs</span>
      <span class="pill">Agents</span>
      <span class="pill">Agentic Frameworks</span>
      <span class="pill">Agentic Commerce</span>
      <span class="pill">Blockchain</span>
      <span class="pill">Stablecoins</span>
      <span class="pill">Tokenization</span>
    </div>
  </section>

  <section class="section" id="track">
    <div class="section-label">Track Record</div>
    <div class="track">
      <div class="track-cell">
        <img class="track-logo" src="/logos/tcs.svg" alt="Tata Consultancy Services" width="30" height="30" />
        <div class="track-year">2012 – 2014</div>
        <div class="track-co">TCS</div>
        <div class="track-role">Systems Engineer</div>
        <div class="track-contrib">Cut my teeth turning client needs into technical solutions.</div>
        <div class="track-skills">
          <span class="chip">Requirements</span>
          <span class="chip">Stakeholders</span>
          <span class="chip">Solutioning</span>
        </div>
      </div>
      <div class="track-cell">
        <img class="track-logo" src="/logos/deloitte.png" alt="Deloitte" width="30" height="30" />
        <div class="track-year">2016 – 2021</div>
        <div class="track-co">Deloitte</div>
        <div class="track-role">Senior Consultant</div>
        <div class="track-contrib">Became a data person: BI that surfaced fraud and drove decisions.</div>
        <div class="track-skills">
          <span class="chip">SQL</span>
          <span class="chip">Power BI</span>
          <span class="chip">Fraud analytics</span>
        </div>
      </div>
      <div class="track-cell">
        <img class="track-logo" src="/logos/delta.svg" alt="Delta Air Lines" width="30" height="30" />
        <div class="track-year">2021 – 2025</div>
        <div class="track-co">Delta</div>
        <div class="track-role">Analytics Program Manager</div>
        <div class="track-contrib">Grew into product ownership; shipped 33 analytics products.</div>
        <div class="track-skills">
          <span class="chip">Python</span>
          <span class="chip">ML</span>
          <span class="chip">Product ownership</span>
        </div>
      </div>
      <div class="track-cell">
        <img class="track-logo" src="/logos/walmart.png" alt="Walmart" width="30" height="30" />
        <div class="track-year">2025 – Now</div>
        <div class="track-co">Walmart</div>
        <div class="track-role">Sr Manager, Payments &amp; Risk</div>
        <div class="track-contrib">Building the credit-risk function 0→1 with production ML and AI agents.</div>
        <div class="track-skills">
          <span class="chip">AI agents</span>
          <span class="chip">Production ML</span>
          <span class="chip">Payments risk</span>
        </div>
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="section" id="writing">
      <div class="section-label">Writing</div>
      {posts.slice(0, 4).map((post) => <PostCard post={post} />)}
    </section>
  )}
</Base>
