---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Blog · Ishan Kunkur" description="Occasional writing on whatever I'm thinking about.">
  <section class="hero" style="padding: 64px 0 24px;">
    <h1>Writing</h1>
    <p>Occasional notes on whatever I'm thinking about: products, AI, books, and the rest.</p>
  </section>

  <section class="section">
    {
      posts.map((post) => (
        <div class="post-item">
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <span class="post-date">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
        </div>
      ))
    }
  </section>
</Base>
