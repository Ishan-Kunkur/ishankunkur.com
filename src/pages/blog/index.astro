---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Writing · Ishan Kunkur" description="Occasional writing on whatever I'm thinking about.">
  <section class="hero" style="padding: 64px 0 24px;">
    <h1>Writing</h1>
    <p>Occasional notes on whatever I'm thinking about: products, AI, books, and the rest.</p>
  </section>

  <section class="section" style="padding-top: 24px;">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</Base>
